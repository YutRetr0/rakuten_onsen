RAKUTEN_APP_ID=your_application_id
RAKUTEN_ACCESS_KEY=your_access_key
RAKUTEN_AFFILIATE_ID=

# === Notifications (configure any one or more) ===

# WeCom group bot (recommended, free, unlimited)
# Get webhook from WeCom group settings -> Add group bot
WECOM_BOT_WEBHOOK=

# Server酱 (push to personal WeChat, free 5/day)
# Get key at https://sct.ftqq.com/
SERVERCHAN_KEY=

# PushPlus (push to personal WeChat, free 200/day)
# Get token at http://www.pushplus.plus/
PUSHPLUS_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# Generic webhook
WEBHOOK_URL=

# Bark (iOS push)
BARK_KEY=

# Watch storage paths (optional)
WATCH_FILE=watchlist.json
STATE_FILE=state.json
